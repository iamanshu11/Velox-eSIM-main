{
  "name": "velox-esim-backend",
  "version": "1.0.0",
  "description": "Velox eSIM Platform - Backend API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.12.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "ts-node-dev --require tsconfig-paths/register src/scripts/seed.ts"
  },
  "scripts": {
    "dev": "ts-node-dev --require tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "prestart": "npm run build",
    "postinstall": "prisma generate || true",
    "prebuild": "prisma generate || true",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "migrate": "prisma migrate dev",
    "seed": "ts-node-dev --require tsconfig-paths/register src/scripts/seed.ts",
    "prisma": "prisma",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push --accept-data-loss"
  },
  "keywords": [
    "esim",
    "telecom"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.13.0",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^14.25.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
