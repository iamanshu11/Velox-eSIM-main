# ═══════════════════════════════════════════════════════════════
# Velox eSIM — Docker environment variables EXAMPLE
# ═══════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.docker.example .env.docker
# 2. Fill in every value marked  <CHANGE_ME>
# 3. NEVER commit .env.docker to git  (it is in .gitignore)
#
# NOTE: DATABASE_URL and REDIS_URL are set automatically by
#       docker-compose.yml using Docker service hostnames.
#       Do NOT add them here.
# ═══════════════════════════════════════════════════════════════

# ─── JWT ──────────────────────────────────────────────────────
# Generate:  openssl rand -hex 64
JWT_SECRET=<CHANGE_ME>
JWT_EXPIRES_IN=7d

# ─── CRM Integration ──────────────────────────────────────────
# Must match VELOX_API_KEY in your CRM backend .env
CRM_API_KEY=<CHANGE_ME>

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_<CHANGE_ME>
STRIPE_PUBLIC_KEY=pk_test_<CHANGE_ME>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<CHANGE_ME>
STRIPE_WEBHOOK_SECRET=whsec_<CHANGE_ME>

# ─── Cloudinary (Image Uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=<CHANGE_ME>
CLOUDINARY_API_KEY=<CHANGE_ME>
CLOUDINARY_API_SECRET=<CHANGE_ME>

# ─── SendGrid (Email) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.<CHANGE_ME>

# ─── eSIM Provider ────────────────────────────────────────────
ESIM_ACCESS_CODE=
ESIM_API_KEY=
ESIM_SECRET_KEY=
ESIM_WEBHOOK_SECRET=

# ─── AI / Chat ────────────────────────────────────────────────
CHAT_FEATURE_ENABLED=true
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_API_KEY=<CHANGE_ME>

# ─── Admin Seed ───────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@veloxesim.com
SEED_ADMIN_PASSWORD=<CHANGE_ME>

# ─── AWS S3 (optional) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ─── Twilio (optional SMS) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/server.log
